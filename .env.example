# ─────────────────────────────────────────────────────────────
# LUMORA SERVER — Environment Variables
# Copy this file to `.env` and fill in real values for local dev.
# On DigitalOcean App Platform, set these in the App Settings UI.
# ─────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=development
PORT=8080

# MongoDB Atlas (same Cluster0 as Glide; different database)
# Format: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/lumora?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/lumora?retryWrites=true&w=majority

# Veilkey (JWT) — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
VEILKEY_SECRET=replace_with_64_char_random_hex_string

# JWT lifetimes
VEILKEY_TTL=7d
VEILKEY_REFRESH_TTL=30d

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://lumoradating.com,https://www.lumoradating.com,http://localhost:3000,http://localhost:8080

# Public base URLs
APP_BASE_URL=https://lumoradating.com
API_BASE_URL=https://api.lumoradating.com

# Admin PIN for Obsidian Console actions (Sentinel-9 break-glass)
# Generate a strong 8-12 char PIN, do not commit
OBSIDIAN_ADMIN_PIN=

# Future integrations (leave blank until used)
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
STRIPE_SECRET_KEY=
